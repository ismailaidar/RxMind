<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RxMind</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RxMind.Web.styles.css" asp-append-version="true" />
    <style>
        body {
            background: #f0f4f8;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }

        .rxmind-nav {
            background: #1a56a4;
            padding: 0 32px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        }

        .rxmind-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .rxmind-brand-icon {
            width: 36px;
            height: 36px;
            background: #fff;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
        }

        .rxmind-brand-text {
            color: #fff;
            font-size: 1.25rem;
            font-weight: 700;
            letter-spacing: -0.3px;
        }

        .rxmind-brand-sub {
            color: #bfdbfe;
            font-size: 0.7rem;
            display: block;
            line-height: 1;
            margin-top: 1px;
        }

        .rxmind-user {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .rxmind-username {
            color: #bfdbfe;
            font-size: 0.875rem;
        }

        .rxmind-signout {
            background: rgba(255,255,255,0.15);
            color: #fff;
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 6px;
            padding: 6px 14px;
            font-size: 0.825rem;
            font-weight: 500;
            text-decoration: none;
            transition: background 0.2s;
        }

        .rxmind-signout:hover {
            background: rgba(255,255,255,0.25);
            color: #fff;
        }

        .rxmind-main {
            max-width: 860px;
            margin: 40px auto;
            padding: 0 20px;
        }

        footer {
            text-align: center;
            padding: 24px;
            font-size: 0.78rem;
            color: #9ca3af;
            border-top: 1px solid #e5e7eb;
            margin-top: 60px;
        }
    </style>
</head>
<body>

    <nav class="rxmind-nav">
        <a class="rxmind-brand" asp-page="/Index">
            <div class="rxmind-brand-icon">💊</div>
            <div>
                <span class="rxmind-brand-text">RxMind</span>
                <span class="rxmind-brand-sub">AI Pharmacy Assistant</span>
            </div>
        </a>

        <div class="rxmind-user">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <span class="rxmind-username">@User.Identity.Name</span>
                <a class="rxmind-signout"
                   asp-area="MicrosoftIdentity"
                   asp-controller="Account"
                   asp-action="SignOut">Sign out</a>
            }
        </div>
    </nav>

    <div class="rxmind-main">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer>
        RxMind &mdash; For demonstration purposes only. Not a substitute for professional medical advice.
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
